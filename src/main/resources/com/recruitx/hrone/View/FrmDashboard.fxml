<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.control.Button?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.ScrollPane?>
<?import javafx.scene.image.Image?>
<?import javafx.scene.image.ImageView?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.Region?>
<?import javafx.scene.layout.VBox?>

<ScrollPane fitToWidth="true" pannable="true" stylesheets="@../Css/FrmDashboard.fx.css" fx:controller="com.recruitx.hrone.Controllers.FrmDashboard" xmlns="http://javafx.com/javafx/20" xmlns:fx="http://javafx.com/fxml/1">
  <content>
    <HBox styleClass="dashboard">
      <VBox styleClass="sidebar">
        <HBox styleClass="brand">
          <ImageView fitHeight="52" fitWidth="52" preserveRatio="true" styleClass="brand-logo">
            <image>
              <Image url="@../Assets/logo.png" />
            </image>
          </ImageView>
          <VBox>
            <Label text="HR One" styleClass="brand-name" />
            <Label text="Espace RH" styleClass="brand-sub" />
          </VBox>
        </HBox>

        <VBox styleClass="nav">
          <Button text="gestion des utilisateurs" styleClass="nav-link" />
          <Button text="gestion administrative" styleClass="nav-link" />
          <Button text="gestion des entretiens" styleClass="nav-link" />
          <Button text="gestion des evenements" styleClass="nav-link" />
          <Button text="gestions des formations" styleClass="nav-link" />
          <Button text="offres d'emploi" styleClass="nav-link" />
          <Button text="formations" styleClass="nav-link" />
          <Button text="communauté" styleClass="nav-link" />
          <Button text="evenements" styleClass="nav-link" />
        </VBox>
      </VBox>

      <VBox styleClass="main" HBox.hgrow="ALWAYS">
        <Region VBox.vgrow="ALWAYS" />
      </VBox>
    </HBox>
  </content>
</ScrollPane>
