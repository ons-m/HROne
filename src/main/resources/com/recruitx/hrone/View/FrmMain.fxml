<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.control.Button?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.ScrollPane?>
<?import javafx.scene.image.Image?>
<?import javafx.scene.image.ImageView?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.VBox?>
<?import javafx.scene.layout.StackPane?>

<ScrollPane fitToWidth="true"
            pannable="true"
            stylesheets="@../Css/FrmMain.fx.css"
            fx:controller="com.recruitx.hrone.Controllers.FrmMain"
            xmlns="http://javafx.com/javafx/20"
            xmlns:fx="http://javafx.com/fxml/1">

    <content>
        <HBox styleClass="dashboard">

            <!-- Sidebar -->
            <VBox styleClass="sidebar" fx:id="sidebar">

                <HBox styleClass="brand">
                    <ImageView fitHeight="52"
                               fitWidth="52"
                               preserveRatio="true"
                               styleClass="brand-logo">
                        <image>
                            <Image url="@../Assets/logo.png"/>
                        </image>
                    </ImageView>

                    <VBox>
                        <Label text="HR One" styleClass="brand-name"/>
                        <Label text="Espace RH" styleClass="brand-sub"/>
                    </VBox>
                </HBox>

                <VBox styleClass="nav">

                    <Button fx:id="btnUsers"
                            text="gestion des utilisateurs"
                            styleClass="nav-link"
                            onAction="#openGestionUsers"/>

                    <Button fx:id="btntracabilite"
                            text="Historique des actions"
                            styleClass="nav-link"
                            onAction="#openTracabilite"/>

                    <Button fx:id="btnParticipation"
                            text="Mes Participations"
                            styleClass="nav-link"
                            onAction="#openParticipations"/>

                    <Button fx:id="btnGestionConge"
                            text="Gestion Des Congés"
                            styleClass="nav-link"
                            onAction="#opengGestionConge"/>

                    <Button fx:id="btnDemandeConge"
                            text="Demande de Congé"
                            styleClass="nav-link"
                            onAction="#openDemangeConge"/>

                    <Button fx:id="btnEmployee"
                            text="gestion administrative"
                            styleClass="nav-link"
                            onAction="#openGestionEmployee"/>

                    <Button fx:id="btnOutils"
                            text="gestion Outils"
                            styleClass="nav-link"
                            onAction="#openGestionOutils"/>

                    <Button fx:id="btnEntretiens"
                            text="gestion des entretiens"
                            styleClass="nav-link"
                            onAction="#openEntretiens"/>

                    <Button fx:id="GestionOffres"
                            text="gestion des offres d'emploi"
                            styleClass="nav-link"
                            onAction="#openGestionOffres"/>

                    <Button fx:id="btnEvenements"
                            text="gestion des evenements"
                            styleClass="nav-link"
                            onAction="#openEvents"/>

                    <Button fx:id="btnFormations"
                            text="gestions des formations"
                            styleClass="nav-link"
                            onAction="#openFormations"/>

                    <Button fx:id="btnOffres"
                            text="offres d'emploi"
                            styleClass="nav-link"
                            onAction="#openOffres"/>

                    <Button fx:id="btnTraining"
                            text="formations"
                            styleClass="nav-link"
                            onAction="#openTraining"/>

                    <Button fx:id="btnCommunaute"
                            text="communauté"
                            styleClass="nav-link"
                            onAction="#openCommunaute"/>

                    <Button fx:id="btnEvents"
                            text="evenements"
                            styleClass="nav-link"
                            onAction="#openEvenements"/>

                </VBox>
            </VBox>

            <!-- Content Area -->
            <VBox styleClass="main" HBox.hgrow="ALWAYS">
                <StackPane fx:id="contentPane"
                           VBox.vgrow="ALWAYS"/>
            </VBox>

        </HBox>
    </content>
</ScrollPane>