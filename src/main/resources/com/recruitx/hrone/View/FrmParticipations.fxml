<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.control.Button?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.ScrollPane?>
<?import javafx.scene.image.ImageView?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.Region?>
<?import javafx.scene.layout.VBox?>

<ScrollPane fitToWidth="true" pannable="true" stylesheets="@../Css/FrmEventsDashboard.fx.css" fx:controller="com.recruitx.hrone.Controllers.FrmParticipation" xmlns="http://javafx.com/javafx/20" xmlns:fx="http://javafx.com/fxml/1">
  <content>
    <HBox styleClass="dashboard">

      <VBox styleClass="main" HBox.hgrow="ALWAYS">
        <HBox styleClass="topbar">
          <Region HBox.hgrow="ALWAYS" />
          <HBox styleClass="user">
            <VBox styleClass="user-info">
              <Label text="Agent RH" styleClass="user-name" />
              <Label text="Participations" styleClass="user-role" />
            </VBox>
            <Label text="AR" styleClass="avatar" />
          </HBox>
        </HBox>

        <VBox styleClass="grid formation-builder">
          <VBox styleClass="card">
            <Label text="Mes Participations" styleClass="section-title" />
            <Label text="Consultez, modifiez ou annulez vos participations aux évènements." styleClass="muted" />
            <VBox fx:id="participationsList" styleClass="resource-list" />
          </VBox>
        </VBox>
      </VBox>
    </HBox>
  </content>
</ScrollPane>
