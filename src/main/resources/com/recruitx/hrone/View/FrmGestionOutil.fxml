<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>

<StackPane stylesheets="@../Css/FrmGestionOutil.fx.css"
           fx:controller="com.recruitx.hrone.Controllers.FrmGestionOutil"
           xmlns="http://javafx.com/javafx/20"
           xmlns:fx="http://javafx.com/fxml/1">

    <!-- MAIN CONTENT -->
    <ScrollPane fitToWidth="true"
                pannable="true"
                styleClass="main-scroll">

        <content>
            <VBox styleClass="main">

                <!-- Topbar -->
                <HBox styleClass="topbar">
                    <VBox styleClass="user-info">
                        <Label text="Agent RH" styleClass="user-name"/>
                        <Label text="Gestion administrative" styleClass="user-role"/>
                    </VBox>
                    <Label text="AR" styleClass="avatar"/>
                </HBox>

                <!-- Page Title -->
                <VBox styleClass="page-title">
                    <Label text="Gerer les outils"
                           styleClass="page-title-text"/>
                    <Label text="Ajoutez et suivez les outils disponibles avec leurs identifiants."
                           styleClass="muted"/>
                </VBox>

                <!-- Card -->
                <VBox styleClass="card">

                    <HBox styleClass="card-header">
                        <VBox>
                            <Label text="Outils disponibles"
                                   styleClass="section-title"/>
                            <Label text="Gerez les outils et leurs identifiants."
                                   styleClass="muted"/>
                        </VBox>

                        <Label text="8 outils"
                               styleClass="pill muted-pill"/>

                        <Button text="Ajouter Outil"
                                styleClass="btn btn-primary"
                                onAction="#handleOpenAddModal"/>
                    </HBox>

                    <TableView fx:id="outilsTable"
                               styleClass="data-table"
                               prefHeight="280">

                        <columns>
                            <TableColumn fx:id="selectColumn"
                                         text=""
                                         prefWidth="40"/>

                            <TableColumn fx:id="nameColumn"
                                         text="Nom de l'outil"
                                         prefWidth="200"/>

                            <TableColumn fx:id="identifiantColumn"
                                         text="IDENTIFIANT_UNIVERSELLE"
                                         prefWidth="210"/>

                            <TableColumn fx:id="hashColumn"
                                         text="HASH_APP"
                                         prefWidth="160"/>

                            <TableColumn fx:id="actionsColumn"
                                         text=""
                                         prefWidth="80"/>
                        </columns>

                    </TableView>

                </VBox>

            </VBox>
        </content>
    </ScrollPane>

    <!-- MODAL OVERLAY -->
    <StackPane fx:id="modalOverlay"
               visible="false"
               managed="false"
               alignment="CENTER"
               styleClass="modal-overlay">

        <VBox styleClass="modal-card">

            <VBox styleClass="card">

                <HBox styleClass="card-header">
                    <VBox>
                        <Label text="Ajouter un outil"
                               styleClass="section-title"/>
                        <Label text="Enregistrez un nouvel outil et ses identifiants."
                               styleClass="muted"/>
                    </VBox>
                </HBox>

                <VBox styleClass="form-vertical">

                    <VBox styleClass="field">
                        <Label text="Nom de l'outil"/>
                        <TextField fx:id="nomField"
                                   promptText="Ex: Outil RH Suite"/>
                    </VBox>

                    <VBox styleClass="field">
                        <Label text="IDENTIFIANT_UNIVERSELLE"/>
                        <TextField fx:id="identifiantField"
                                   promptText="Ex: RH-UNI-0001"/>
                    </VBox>

                    <VBox styleClass="field">
                        <Label text="HASH_APP"/>
                        <TextField fx:id="hashField"
                                   promptText="Ex: a1b2c3d4e5"/>
                    </VBox>

                    <HBox styleClass="form-actions">
                        <Button fx:id="confirmButton"
                                text="Valider"
                                styleClass="btn btn-primary"
                                onAction="#handleConfirm"/>

                        <Button fx:id="cancelButton"
                                text="Annuler"
                                onAction="#handleCloseModal"/>
                    </HBox>

                </VBox>
            </VBox>
        </VBox>

    </StackPane>

</StackPane>