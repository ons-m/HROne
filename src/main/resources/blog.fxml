<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>
<?import javafx.geometry.Insets?>
<?import javafx.scene.shape.Circle?>
<?import javafx.scene.text.Font?>
<?import javafx.scene.text.Text?>

<ScrollPane fitToWidth="true" pannable="true" style="-fx-background: transparent; -fx-background-color: transparent;" xmlns="http://javafx.com/javafx/17" xmlns:fx="http://javafx.com/fxml/1" fx:controller="com.recruitx.hrone.BlogController">
    <content>
        <VBox spacing="25" style="-fx-background-color: linear-gradient(to bottom, #f0f4f8, #e6ecf5);">
            <padding>
                <Insets top="25" right="30" bottom="25" left="30"/>
            </padding>

            <!-- HEADER -->
            <HBox alignment="CENTER_LEFT" spacing="20" style="-fx-background-color: #1a2b4c; -fx-padding: 15 25; -fx-background-radius: 20; -fx-effect: dropshadow(gaussian, rgba(26,43,76,0.3), 15, 0, 0, 5);">
                <HBox spacing="12" alignment="CENTER_LEFT">
                    <Circle radius="28" style="-fx-fill: linear-gradient(to bottom right, #2c3e6d, #0f1a2f); -fx-stroke: #4a6fa5; -fx-stroke-width: 2;" />
                    <VBox>
                        <Label text="HR One" style="-fx-font-size: 28px; -fx-font-weight: bold; -fx-text-fill: white;">
                            <font>
                                <Font name="System Bold" size="28"/>
                            </font>
                        </Label>
                        <Label text="Employee Forum" style="-fx-text-fill: #a3c2e0; -fx-font-size: 14px;" />
                    </VBox>
                </HBox>
                <Region HBox.hgrow="ALWAYS" />
                <HBox spacing="15" alignment="CENTER">
                    <Button text="🔔" style="-fx-background-color: #2c3e6d; -fx-text-fill: white; -fx-padding: 10 15; -fx-background-radius: 25; -fx-font-size: 16px; -fx-cursor: hand;" />
                    <Button text="✉️" style="-fx-background-color: #2c3e6d; -fx-text-fill: white; -fx-padding: 10 15; -fx-background-radius: 25; -fx-font-size: 16px; -fx-cursor: hand;" />
                    <Button text="👤 Admin" style="-fx-background-color: #4a6fa5; -fx-text-fill: white; -fx-padding: 10 25; -fx-background-radius: 25; -fx-font-size: 14px; -fx-font-weight: bold; -fx-cursor: hand;" />
                </HBox>
            </HBox>

            <!-- BANNER HERO AVEC MÉTÉO -->
            <HBox spacing="20">
                <!-- Hero principal -->
                <VBox spacing="20" style="-fx-background-color: linear-gradient(to right, #1e3a6b, #2b4c8c); -fx-padding: 40; -fx-background-radius: 20; -fx-effect: dropshadow(gaussian, rgba(30,58,107,0.4), 20, 0, 0, 5);" HBox.hgrow="ALWAYS">
                    <VBox spacing="10">
                        <Label text="✨ Share Your Ideas ✨" style="-fx-font-size: 38px; -fx-font-weight: bold; -fx-text-fill: white;" />
                        <Text text="Post suggestions, ask questions, and keep the conversation moving." style="-fx-fill: rgba(255,255,255,0.9); -fx-font-size: 16px;" wrappingWidth="500" />
                    </VBox>
                    <HBox spacing="15" alignment="CENTER" style="-fx-padding: 20 0 0 0;">
                        <TextField fx:id="searchField" promptText="🔍 Search topics, teams, or tags..." HBox.hgrow="ALWAYS" style="-fx-padding: 15 20; -fx-background-radius: 30; -fx-font-size: 15px; -fx-background-color: white; -fx-effect: dropshadow(gaussian, rgba(0,0,0,0.1), 5, 0, 0, 2);" />
                        <Button fx:id="searchButton" text="🔍 Search" style="-fx-background-color: #f39c12; -fx-text-fill: white; -fx-padding: 15 35; -fx-background-radius: 30; -fx-font-size: 15px; -fx-font-weight: bold; -fx-cursor: hand; -fx-effect: dropshadow(gaussian, rgba(0,0,0,0.2), 5, 0, 0, 2);" />
                    </HBox>
                </VBox>

                <!-- Widget Météo -->
                <VBox spacing="15" style="-fx-background-color: #1a2b4c; -fx-padding: 25; -fx-background-radius: 20; -fx-effect: dropshadow(gaussian, rgba(26,43,76,0.3), 10, 0, 0, 5);" prefWidth="200">
                    <Label text="☀️ Météo du jour" style="-fx-font-size: 18px; -fx-font-weight: bold; -fx-text-fill: white;" />
                    <Label fx:id="weatherCityLabel" text="Paris" style="-fx-text-fill: #a3c2e0; -fx-font-size: 14px;" />
                    <Label fx:id="weatherTempLabel" text="22°C" style="-fx-text-fill: white; -fx-font-size: 32px; -fx-font-weight: bold;" />
                    <Label fx:id="weatherDescLabel" text="Ensoleillé" style="-fx-text-fill: #a3c2e0; -fx-font-size: 14px;" />
                    <Button fx:id="refreshWeatherBtn" text="🔄 Actualiser" style="-fx-background-color: #2c3e6d; -fx-text-fill: white; -fx-padding: 8; -fx-background-radius: 15; -fx-cursor: hand;" />
                </VBox>
            </HBox>

            <!-- CONTENU PRINCIPAL -->
            <HBox spacing="25">
                <!-- Feed des posts (le formulaire sera ajouté automatiquement par le contrôleur) -->
                <VBox fx:id="feedContainer" spacing="20" HBox.hgrow="ALWAYS" />

                <!-- Sidebar avec APIs et Chatbot -->
                <VBox fx:id="sidePanel" prefWidth="400" spacing="20">

                    <!-- SECTION : APIs -->
                    <VBox style="-fx-background-color: white; -fx-padding: 25; -fx-background-radius: 20; -fx-effect: dropshadow(gaussian, rgba(26,43,76,0.1), 10, 0, 0, 2);" spacing="15">
                        <HBox spacing="10" alignment="CENTER_LEFT">
                            <Circle radius="15" style="-fx-fill: #1a2b4c;" />
                            <Label text="⚡ APIs &amp; Outils" style="-fx-font-size: 20px; -fx-font-weight: bold; -fx-text-fill: #1a2b4c;" />
                        </HBox>

                        <GridPane hgap="10" vgap="10">
                            <Button fx:id="weatherBtn" text="☀️ Météo" GridPane.rowIndex="0" GridPane.columnIndex="0" style="-fx-background-color: #1a2b4c; -fx-text-fill: white; -fx-padding: 12; -fx-background-radius: 10; -fx-cursor: hand;" maxWidth="Infinity" />
                            <Button fx:id="adviceBtn" text="💡 Conseil" GridPane.rowIndex="0" GridPane.columnIndex="1" style="-fx-background-color: #2c3e6d; -fx-text-fill: white; -fx-padding: 12; -fx-background-radius: 10; -fx-cursor: hand;" maxWidth="Infinity" />

                            <Button fx:id="quoteBtn" text="📝 Citation" GridPane.rowIndex="1" GridPane.columnIndex="0" style="-fx-background-color: #1a2b4c; -fx-text-fill: white; -fx-padding: 12; -fx-background-radius: 10; -fx-cursor: hand;" maxWidth="Infinity" />
                            <Button fx:id="jokeBtn" text="😂 Blague" GridPane.rowIndex="1" GridPane.columnIndex="1" style="-fx-background-color: #2c3e6d; -fx-text-fill: white; -fx-padding: 12; -fx-background-radius: 10; -fx-cursor: hand;" maxWidth="Infinity" />

                            <Button fx:id="animalBtn" text="🐕 Image d'animal" GridPane.rowIndex="2" GridPane.columnIndex="0" style="-fx-background-color: #1a2b4c; -fx-text-fill: white; -fx-padding: 12; -fx-background-radius: 10; -fx-cursor: hand;" maxWidth="Infinity" />
                            <Button fx:id="translateBtn" text="🌐 Traduire" GridPane.rowIndex="2" GridPane.columnIndex="1" style="-fx-background-color: #2c3e6d; -fx-text-fill: white; -fx-padding: 12; -fx-background-radius: 10; -fx-cursor: hand;" maxWidth="Infinity" />

                            <Button fx:id="emailBtn" text="📧 Email" GridPane.rowIndex="3" GridPane.columnIndex="0" style="-fx-background-color: #1a2b4c; -fx-text-fill: white; -fx-padding: 12; -fx-background-radius: 10; -fx-cursor: hand;" maxWidth="Infinity" />
                            <Button fx:id="newsletterBtn" text="📰 Newsletter" GridPane.rowIndex="3" GridPane.columnIndex="1" style="-fx-background-color: #2c3e6d; -fx-text-fill: white; -fx-padding: 12; -fx-background-radius: 10; -fx-cursor: hand;" maxWidth="Infinity" />

                            <Button fx:id="sentimentBtn" text="😊 Sentiment" GridPane.rowIndex="4" GridPane.columnIndex="0" style="-fx-background-color: #1a2b4c; -fx-text-fill: white; -fx-padding: 12; -fx-background-radius: 10; -fx-cursor: hand;" maxWidth="Infinity" GridPane.columnSpan="2" />
                        </GridPane>
                    </VBox>

                    <!-- SECTION : CHATBOT -->
                    <VBox style="-fx-background-color: white; -fx-padding: 25; -fx-background-radius: 20; -fx-effect: dropshadow(gaussian, rgba(26,43,76,0.2), 15, 0, 0, 5); -fx-border-color: #1a2b4c; -fx-border-width: 0 0 0 5; -fx-border-radius: 20;" spacing="15">
                        <HBox spacing="10" alignment="CENTER_LEFT">
                            <Circle radius="15" style="-fx-fill: #1a2b4c;" />
                            <Label text="🤖 Assistant IA" style="-fx-font-size: 20px; -fx-font-weight: bold; -fx-text-fill: #1a2b4c;" />
                            <Label text="(en ligne)" style="-fx-text-fill: #27ae60; -fx-font-size: 12px; -fx-background-color: #e8f5e9; -fx-padding: 3 10; -fx-background-radius: 15;" />
                        </HBox>

                        <!-- Zone de chat avec ScrollPane -->
                        <ScrollPane fitToWidth="true" style="-fx-background: transparent; -fx-background-color: transparent;" prefHeight="200">
                            <VBox fx:id="chatContainer" spacing="10" style="-fx-background-color: #f8fafc; -fx-padding: 15; -fx-background-radius: 15;" />
                        </ScrollPane>

                        <!-- Input pour le chat -->
                        <HBox spacing="10">
                            <TextField fx:id="chatInputField" promptText="Posez votre question..." HBox.hgrow="ALWAYS" style="-fx-padding: 12; -fx-background-radius: 25; -fx-border-color: #cbd5e0; -fx-border-radius: 25;" />
                            <Button fx:id="sendChatBtn" text="📤 Envoyer" style="-fx-background-color: #1a2b4c; -fx-text-fill: white; -fx-padding: 12 20; -fx-background-radius: 25; -fx-cursor: hand;" />
                        </HBox>

                        <!-- Suggestions rapides -->
                        <FlowPane hgap="8" vgap="8">
                            <Button text="❓ Aide" style="-fx-background-color: #e2e8f0; -fx-text-fill: #1a2b4c; -fx-padding: 8 15; -fx-background-radius: 20; -fx-cursor: hand;" />
                            <Button text="📊 Stats" style="-fx-background-color: #e2e8f0; -fx-text-fill: #1a2b4c; -fx-padding: 8 15; -fx-background-radius: 20; -fx-cursor: hand;" />
                            <Button text="👥 Users" style="-fx-background-color: #e2e8f0; -fx-text-fill: #1a2b4c; -fx-padding: 8 15; -fx-background-radius: 20; -fx-cursor: hand;" />
                            <Button text="📅 Events" style="-fx-background-color: #e2e8f0; -fx-text-fill: #1a2b4c; -fx-padding: 8 15; -fx-background-radius: 20; -fx-cursor: hand;" />
                        </FlowPane>
                    </VBox>

                    <!-- SECTION : Tags populaires -->
                    <VBox style="-fx-background-color: white; -fx-padding: 25; -fx-background-radius: 20; -fx-effect: dropshadow(gaussian, rgba(26,43,76,0.1), 10, 0, 0, 2);" spacing="15">
                        <HBox spacing="10" alignment="CENTER_LEFT">
                            <Circle radius="15" style="-fx-fill: #1a2b4c;" />
                            <Label text="🏷️ Tags populaires" style="-fx-font-size: 20px; -fx-font-weight: bold; -fx-text-fill: #1a2b4c;" />
                        </HBox>
                        <FlowPane hgap="10" vgap="10">
                            <Label text="#Onboarding" style="-fx-background-color: #e1f5fe; -fx-padding: 8 18; -fx-background-radius: 25; -fx-border-color: #1a2b4c; -fx-border-radius: 25; -fx-cursor: hand;" />
                            <Label text="#Benefits" style="-fx-background-color: #e8f5e9; -fx-padding: 8 18; -fx-background-radius: 25; -fx-border-color: #1a2b4c; -fx-border-radius: 25; -fx-cursor: hand;" />
                            <Label text="#Culture" style="-fx-background-color: #f3e5f5; -fx-padding: 8 18; -fx-background-radius: 25; -fx-border-color: #1a2b4c; -fx-border-radius: 25; -fx-cursor: hand;" />
                            <Label text="#Remote" style="-fx-background-color: #fff3e0; -fx-padding: 8 18; -fx-background-radius: 25; -fx-border-color: #1a2b4c; -fx-border-radius: 25; -fx-cursor: hand;" />
                        </FlowPane>
                    </VBox>

                    <!-- SECTION : Statistiques -->
                    <VBox style="-fx-background-color: #1a2b4c; -fx-padding: 25; -fx-background-radius: 20; -fx-effect: dropshadow(gaussian, rgba(26,43,76,0.3), 15, 0, 0, 5);" spacing="15">
                        <Label text="📊 Statistiques" style="-fx-font-size: 20px; -fx-font-weight: bold; -fx-text-fill: white;" />
                        <GridPane hgap="15" vgap="12">
                            <Label text="Membres:" GridPane.rowIndex="0" GridPane.columnIndex="0" style="-fx-text-fill: #a3c2e0;" />
                            <Label text="1,234" GridPane.rowIndex="0" GridPane.columnIndex="1" style="-fx-font-weight: bold; -fx-text-fill: white;" />

                            <Label text="Posts:" GridPane.rowIndex="1" GridPane.columnIndex="0" style="-fx-text-fill: #a3c2e0;" />
                            <Label text="456" GridPane.rowIndex="1" GridPane.columnIndex="1" style="-fx-font-weight: bold; -fx-text-fill: white;" />

                            <Label text="Commentaires:" GridPane.rowIndex="2" GridPane.columnIndex="0" style="-fx-text-fill: #a3c2e0;" />
                            <Label text="2,891" GridPane.rowIndex="2" GridPane.columnIndex="1" style="-fx-font-weight: bold; -fx-text-fill: white;" />
                        </GridPane>
                    </VBox>
                </VBox>
            </HBox>

            <!-- FOOTER -->
            <HBox alignment="CENTER" spacing="20" style="-fx-background-color: white; -fx-padding: 20 25; -fx-background-radius: 15; -fx-effect: dropshadow(gaussian, rgba(0,0,0,0.05), 5, 0, 0, 2);">
                <Label text="© 2026 HR One - Employee Forum" style="-fx-text-fill: #7f8c8d;" />
                <Region HBox.hgrow="ALWAYS" />
                <Label text="À propos" style="-fx-text-fill: #1a2b4c; -fx-cursor: hand;" />
                <Label text="•" style="-fx-text-fill: #bdc3c7;" />
                <Label text="Confidentialité" style="-fx-text-fill: #1a2b4c; -fx-cursor: hand;" />
                <Label text="•" style="-fx-text-fill: #bdc3c7;" />
                <Label text="Contact" style="-fx-text-fill: #1a2b4c; -fx-cursor: hand;" />
            </HBox>
        </VBox>
    </content>
</ScrollPane>