DROP TABLE IF EXISTS detail_formation;
DROP TABLE IF EXISTS certification;
DROP TABLE IF EXISTS formation;
DROP TABLE IF EXISTS participation_formation;

CREATE TABLE `participation_formation` (
  `ID_Formation` int(11) NOT NULL,
  `ID_Participant` int(11) NOT NULL,
  `Num_Ordre_Participation` bigint(20) NOT NULL,
  `Statut` varchar(20) DEFAULT 'inscrit',
  `Certificat` varchar(255) DEFAULT NULL
) ENGINE=InnoDB DEFAULT CHARSET=utf8mb4 COLLATE=utf8mb4_general_ci;

CREATE TABLE `formation` (
  `ID_Formation` int(11) NOT NULL,
  `Titre` varchar(255) NOT NULL,
  `Description` text DEFAULT NULL,
  `Num_Ordre_Creation` int(11) NOT NULL,
  `ID_Entreprise` int(11) NOT NULL,
  `Image` varchar(255) DEFAULT NULL,
  `Mode` varchar(20) DEFAULT 'presentiel',
  `NombrePlaces` int(11) DEFAULT 30,
  `PlacesRestantes` int(11) DEFAULT 30,
  `Date_Debut` bigint(20) DEFAULT 0,
  `Date_Fin` bigint(20) DEFAULT 0,
  `Niveau` varchar(20) DEFAULT 'Débutant'
);

CREATE TABLE `certification` (
  `ID_Certif` int(11) NOT NULL,
  `ID_Formation` int(11) NOT NULL,
  `ID_Participant` int(11) NOT NULL,
  `Description_Certif` varchar(255) DEFAULT NULL,
  `Fichier_PDF` longblob DEFAULT NULL
);


